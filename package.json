{
  "name": "elz-ui",
  "version": "1.0.0",
  "description": "Elz UI — accessible React component library",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "test": "pnpm -r --filter './packages/*' test",
    "dev": "pnpm --filter @elz-ui/playground dev",
    "typecheck": "pnpm -r --filter './packages/*' typecheck",
    "publish:packages": "pnpm -r --filter './packages/*' publish --access public"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/jest-dom": "^6.6.0",
    "jsdom": "^26.1.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@11.12.0",
  "license": "MIT"
}
