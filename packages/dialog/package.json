{
  "name": "@elz-ui/dialog",
  "version": "0.1.1",
  "description": "Accessible modal dialog for Elz UI",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@elz-ui/core": ">=0.1.0"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.14"
  },
  "devDependencies": {
    "@elz-ui/core": "workspace:*",
    "typescript": "^5.9.0",
    "tsup": "^8.5.0",
    "vitest": "^3.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
